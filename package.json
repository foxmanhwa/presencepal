{
  "name": "presencepal",
  "version": "1.0.0",
  "description": "Set your Discord game activity from any game — even mobile games",
  "author": "foxmanhwa",
  "license": "MIT",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "keywords": [
    "discord",
    "rich-presence",
    "rpc",
    "electron",
    "mobile-games"
  ],
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  },
  "build": {
    "appId": "com.presencepal.app",
    "productName": "PresencePal",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "assets/runner.exe",
        "to": "runner.exe"
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.png"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/runner.exe",
      "node_modules/**/*",
      "package.json"
    ]
  }
}
